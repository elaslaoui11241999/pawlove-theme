<nav class="navbar">
  <a href="{{ routes.root_url }}" class="nb-logo"><span class="paw">🐾</span>Paw<span>Love</span></a>
  <div class="nb-right">
    <a href="{{ routes.cart_url }}" class="nb-btn">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="nb-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<div style="background:var(--cream);min-height:70vh">
  <div class="container" style="padding-top:48px;padding-bottom:72px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start">
    <div style="background:var(--warm);border-radius:24px;aspect-ratio:1;overflow:hidden;display:flex;align-items:center;justify-content:center">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '700x700', crop: 'center' }}" alt="{{ product.title | escape }}" style="width:100%;height:100%;object-fit:cover">
      {% else %}
        <span style="font-size:80px">🐾</span>
      {% endif %}
    </div>
    <div style="display:flex;flex-direction:column;gap:16px;padding-top:16px">
      <div class="prod-brand">{{ product.type }}</div>
      <h1 style="font-family:'Fraunces',serif;font-size:clamp(24px,4vw,42px);font-weight:900;line-height:1.1">{{ product.title }}</h1>
      <div class="prod-prices">
        <span class="pp-now" style="font-size:28px">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="pp-old" style="font-size:16px">{{ product.compare_at_price | money }}</span>
          {% assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="pp-save">-{{ saved }}%</span>
        {% endif %}
      </div>
      <p style="font-size:14px;color:var(--gray);line-height:1.8">{{ product.description }}</p>
      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;font-size:15px;padding:17px">
          🐾 Añadir al carrito — {{ product.price | money }}
        </button>
      {% endform %}
      <div style="background:var(--warm);border-radius:14px;padding:14px 18px;font-size:12px;color:var(--gray);line-height:1.8">
        <strong style="color:var(--brown);display:block;margin-bottom:4px">📦 Envío</strong>
        Entrega estimada 8–18 días hábiles · Gratis en pedidos +40€
      </div>
    </div>
  </div>
</div>
