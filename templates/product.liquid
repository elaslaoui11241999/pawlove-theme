<nav class="navbar">
  <a href="{{ routes.root_url }}" class="nb-logo"><span class="paw">&#x1F43E;</span>pow<span>love</span></a>
  <div class="nb-right">
    <a href="{{ routes.cart_url }}" class="nb-btn">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="nb-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<style>
html,body{overflow-x:hidden;max-width:100vw}
.pdp{max-width:680px;margin:0 auto;padding:24px 16px 100px;box-sizing:border-box}
.pdp-img{width:100%;aspect-ratio:1;object-fit:contain;border-radius:20px;background:var(--warm);display:block}
.pdp-thumbs{display:flex;gap:8px;margin-top:10px;overflow-x:auto;padding-bottom:4px}
.pdp-thumbs img{width:64px;height:64px;flex-shrink:0;object-fit:cover;border-radius:10px;cursor:pointer;border:2px solid transparent}
.pdp-thumbs img.on,.pdp-thumbs img:hover{border-color:var(--orange)}
.pdp-info{margin-top:24px;display:flex;flex-direction:column;gap:14px}
.oferta-banner{display:flex;align-items:center;gap:10px}
.oferta-line{flex:1;height:1px;background:var(--orange)}
.oferta-text{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--orange);white-space:nowrap}
.cdw-wrap{background:var(--warm);border-radius:14px;padding:12px;text-align:center}
.cdw-label{font-size:11px;color:var(--gray);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.cdw-nums{display:flex;justify-content:center;align-items:flex-start;gap:4px}
.cdw-block{text-align:center}
.cdw-n{font-family:'Fraunces',serif;font-size:32px;font-weight:900;color:var(--brown);line-height:1}
.cdw-l{font-size:9px;color:var(--gray);margin-top:2px}
.cdw-sep{font-family:'Fraunces',serif;font-size:32px;font-weight:900;color:var(--orange);line-height:1;padding:0 2px}
.var-card{display:flex;align-items:center;gap:12px;padding:12px 14px;border:2px solid rgba(44,31,20,.12);border-radius:14px;cursor:pointer;transition:all .2s;position:relative;background:#fff;box-sizing:border-box;width:100%}
.var-card:hover{border-color:var(--orange)}
.var-card.selected{border-color:var(--orange);background:rgba(233,107,42,.04)}
.var-radio{width:20px;height:20px;border-radius:50%;border:2px solid var(--gray2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s}
.var-card.selected .var-radio{border-color:var(--orange);background:var(--orange)}
.var-card.selected .var-radio::after{content:'';width:8px;height:8px;border-radius:50%;background:#fff}
.var-swatch{width:22px;height:22px;border-radius:50%;flex-shrink:0;border:2px solid #fff;box-shadow:0 0 0 1px rgba(44,31,20,.18)}
.var-name{font-size:13px;font-weight:700;color:var(--brown);flex:1;min-width:0}
.var-price{font-family:'Fraunces',serif;font-size:17px;font-weight:900;color:var(--brown);flex-shrink:0}
.var-old{font-size:11px;color:var(--gray2);text-decoration:line-through;text-align:right}
.var-badge{position:absolute;top:-10px;right:12px;background:var(--orange);color:#fff;font-size:10px;font-weight:800;padding:3px 10px;border-radius:999px}
.pay-btn{width:100%;padding:16px;border-radius:14px;font-size:15px;font-weight:800;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .2s;box-sizing:border-box}
</style>

<div style="background:var(--cream);min-height:80vh;overflow:hidden">
  <div class="pdp">
    {% if product.featured_image %}
      <img id="mainImg" class="pdp-img" src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title | escape }}">
    {% else %}
      <div class="pdp-img" style="display:flex;align-items:center;justify-content:center;font-size:80px">&#x1F43E;</div>
    {% endif %}
    {% if product.images.size > 1 %}
      <div class="pdp-thumbs">
        {% for image in product.images limit: 12 %}
          <img src="{{ image | img_url: '160x160' }}" data-full="{{ image | img_url: '800x' }}" alt="" class="{% if forloop.first %}on{% endif %}" onclick="swImg(this)">
        {% endfor %}
      </div>
    {% endif %}

    <div class="pdp-info">
      <h1 style="font-family:'Fraunces',serif;font-size:clamp(22px,5vw,34px);font-weight:900;line-height:1.15;color:var(--brown)">{{ product.title }}</h1>
      <div style="color:var(--gold);font-size:16px">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</div>

      <div class="oferta-banner">
        <div class="oferta-line"></div>
        <span class="oferta-text">&#x26A1; Oferta por tiempo limitado</span>
        <div class="oferta-line"></div>
      </div>

      <div class="cdw-wrap">
        <div class="cdw-label">La oferta termina en</div>
        <div class="cdw-nums">
          <div class="cdw-block"><div class="cdw-n" id="cd-h">00</div><div class="cdw-l">Horas</div></div>
          <div class="cdw-sep">:</div>
          <div class="cdw-block"><div class="cdw-n" id="cd-m">00</div><div class="cdw-l">Mins</div></div>
          <div class="cdw-sep">:</div>
          <div class="cdw-block"><div class="cdw-n" id="cd-s">00</div><div class="cdw-l">Seg</div></div>
        </div>
      </div>

      {% if product.variants.size > 1 %}
        <div style="display:flex;flex-direction:column;gap:10px">
          {% for variant in product.variants %}
            {% assign cname = variant.title | downcase %}
            {% assign swatch = '' %}
            {% if cname contains 'negro' %}{% assign swatch = '#1c1c1c' %}
            {% elsif cname contains 'blanco' %}{% assign swatch = '#f2f2f2' %}
            {% elsif cname contains 'azul gris' %}{% assign swatch = '#6e84a3' %}
            {% elsif cname contains 'gris' %}{% assign swatch = '#9a9a9a' %}
            {% elsif cname contains 'púrpura' or cname contains 'purpura' %}{% assign swatch = '#8e3b5e' %}
            {% elsif cname contains 'morado' %}{% assign swatch = '#7b3fb0' %}
            {% elsif cname contains 'verde claro' %}{% assign swatch = '#8bc34a' %}
            {% elsif cname contains 'verde' %}{% assign swatch = '#3a8c5a' %}
            {% elsif cname contains 'azul' %}{% assign swatch = '#2f6fed' %}
            {% elsif cname contains 'rojo' or cname contains 'roja' %}{% assign swatch = '#e84545' %}
            {% elsif cname contains 'rosa' %}{% assign swatch = '#f48fb1' %}
            {% elsif cname contains 'amarillo' %}{% assign swatch = '#f2c200' %}
            {% elsif cname contains 'naranja' %}{% assign swatch = '#e96b2a' %}
            {% endif %}
            <div class="var-card {% if forloop.first %}selected{% endif %}" onclick="selectVariant(this,'{{ variant.id }}')">
              {% if forloop.index == 2 %}<div class="var-badge">&#x2605; Mas popular</div>{% endif %}
              <div class="var-radio"></div>
              {% if swatch != '' %}<span class="var-swatch" style="background:{{ swatch }}"></span>{% endif %}
              <div class="var-name">{{ variant.title }}</div>
              <div style="text-align:right;flex-shrink:0">
                <div class="var-price">{{ variant.price | money }}</div>
                {% if variant.compare_at_price > variant.price %}<div class="var-old">{{ variant.compare_at_price | money }}</div>{% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div style="font-family:'Fraunces',serif;font-size:32px;font-weight:900;color:var(--brown)">{{ product.price | money }}</div>
      {% endif %}

      {% if product.description != blank %}
        <div style="font-size:14px;color:var(--gray);line-height:1.9;border-top:1px solid rgba(44,31,20,.07);padding-top:14px">{{ product.description | truncate: 400 }}</div>
      {% endif %}

      {% form 'product', product %}
        <input type="hidden" name="id" id="selectedVariant" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" name="checkout" class="pay-btn" style="background:var(--brown);color:#fff;margin-bottom:10px">&#x1F4B3; Pagar ahora</button>
        <button type="submit" class="pay-btn" style="background:var(--orange);color:#fff">&#x1F6D2; Agregar al carrito</button>
      {% endform %}

      <div style="background:var(--warm);border-radius:14px;padding:14px 18px;font-size:13px;color:var(--gray);line-height:1.8">
        <strong style="color:var(--brown);display:block;margin-bottom:4px">&#x1F4E6; Envio gratuito</strong>
        Entrega estimada 8-18 dias &#x00B7; Gratis en pedidos +40&#x20AC;
      </div>

      <a href="javascript:history.back()" style="font-size:13px;color:var(--gray);text-align:center;display:block">&#x2190; Volver</a>
    </div>
  </div>
</div>

<script>
function swImg(t){
  document.getElementById('mainImg').src=t.dataset.full;
  document.querySelectorAll('.pdp-thumbs img').forEach(i=>i.classList.remove('on'));
  t.classList.add('on');
}
function selectVariant(card,id){
  document.querySelectorAll('.var-card').forEach(c=>c.classList.remove('selected'));
  card.classList.add('selected');
  document.getElementById('selectedVariant').value=id;
}
(function(){
  function pad(n){return String(n).padStart(2,'0')}
  function tick(){
    var now=new Date(),end=new Date(now);
    end.setHours(23,59,59,0);
    var d=Math.max(0,Math.floor((end-now)/1000));
    document.getElementById('cd-h').textContent=pad(Math.floor(d/3600));
    document.getElementById('cd-m').textContent=pad(Math.floor((d%3600)/60));
    document.getElementById('cd-s').textContent=pad(d%60);
  }
  tick();setInterval(tick,1000);
})();
</script>
