<nav class="navbar">
  <a href="{{ routes.root_url }}" class="nb-logo">
    <span class="paw">&#x1F43E;</span>Paw<span>Love</span>
  </a>
  <div class="nb-right">
    <a href="{{ routes.cart_url }}" class="nb-btn">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="nb-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<style>
.pdp { display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:start; padding:40px 0 80px; }
.pdp-gallery img.main { width:100%; aspect-ratio:1; object-fit:cover; border-radius:20px; display:block; }
.pdp-thumbs { display:flex; gap:8px; margin-top:10px; overflow-x:auto; padding-bottom:4px; }
.pdp-thumbs img { width:72px; height:72px; flex-shrink:0; object-fit:cover; border-radius:10px; cursor:pointer; border:2px solid transparent; transition:border-color .2s; }
.pdp-thumbs img.on, .pdp-thumbs img:hover { border-color:var(--orange); }
.pdp-info { display:flex; flex-direction:column; gap:16px; }
.pdp-desc { font-size:14px; color:var(--gray); line-height:1.9; border-top:1px solid rgba(44,31,20,.07); padding-top:16px; }
.pdp-buy { width:100%; justify-content:center; font-size:15px; padding:17px; }
.pdp-ship { background:var(--warm); border-radius:14px; padding:14px 18px; font-size:13px; color:var(--gray); line-height:1.8; }
.pdp-back { font-size:13px; color:var(--gray); text-align:center; display:block; }
@media(max-width:760px){
  .pdp { grid-template-columns:1fr; gap:0; padding:0 0 60px; }
  .pdp-gallery img.main { border-radius:0; }
  .pdp-info { padding:20px; }
  .pdp-thumbs { padding:0 20px 4px; }
}
</style>

<div style="background:var(--cream);min-height:70vh">
  <div class="container">
    <div class="pdp">

      <!-- GALERÍA -->
      <div class="pdp-gallery">
        {% if product.images.size > 0 %}
          <img class="main" id="mainImg"
               src="{{ product.images[0] | img_url: '800x800', crop: 'center' }}"
               alt="{{ product.title | escape }}">
          {% if product.images.size > 1 %}
            <div class="pdp-thumbs">
              {% for image in product.images limit: 12 %}
                <img src="{{ image | img_url: '200x200', crop: 'center' }}"
                     data-full="{{ image | img_url: '800x800', crop: 'center' }}"
                     alt="{{ product.title | escape }}"
                     class="{% if forloop.first %}on{% endif %}"
                     onclick="switchImg(this)">
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div style="aspect-ratio:1;background:var(--warm);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:80px">&#x1F43E;</div>
        {% endif %}
      </div>

      <!-- INFO -->
      <div class="pdp-info">
        <div class="prod-brand">{{ product.type | default: 'PawLove' }}</div>

        <h1 style="font-family:'Fraunces',serif;font-size:clamp(22px,3vw,36px);font-weight:900;line-height:1.1;color:var(--brown)">
          {{ product.title }}
        </h1>

        <div style="color:var(--gold);font-size:16px">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</div>

        <div class="prod-prices">
          <span class="pp-now" style="font-size:28px">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="pp-old">{{ product.compare_at_price | money }}</span>
            {% assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
            <span class="pp-save">-{{ saved }}%</span>
          {% endif %}
        </div>

        {% if product.description != blank %}
          <div class="pdp-desc">{{ product.description }}</div>
        {% endif %}

        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button type="submit" name="checkout" class="btn-primary pdp-buy">
            &#x1F43E; Comprar ahora — {{ product.price | money }}
          </button>
        {% endform %}

        <div class="pdp-ship">
          <strong style="color:var(--brown);display:block;margin-bottom:4px">&#x1F4E6; Envio</strong>
          Entrega 8-18 dias · Gratis en pedidos +40€
        </div>

        <a href="javascript:history.back()" class="pdp-back">&#x2190; Volver</a>
      </div>

    </div>
  </div>
</div>

<script>
function switchImg(t){
  document.getElementById('mainImg').src=t.dataset.full;
  document.querySelectorAll('.pdp-thumbs img').forEach(i=>i.classList.remove('on'));
  t.classList.add('on');
}
</script>
