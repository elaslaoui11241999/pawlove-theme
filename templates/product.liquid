<nav class="navbar">
  <a href="{{ routes.root_url }}" class="nb-logo">
    <span class="paw">&#x1F43E;</span>Paw<span>Love</span>
  </a>
  <div class="nb-right">
    <a href="{{ routes.cart_url }}" class="nb-btn">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="nb-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<style>
.pdp-wrap { max-width:1100px; margin:0 auto; padding:40px 20px 80px; display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start; }
.pdp-img-main { width:100%; height:480px; object-fit:contain; border-radius:20px; background:var(--warm); display:block; }
.pdp-thumbs { display:flex; gap:8px; margin-top:10px; overflow-x:auto; padding-bottom:4px; }
.pdp-thumbs img { width:70px; height:70px; flex-shrink:0; object-fit:cover; border-radius:10px; cursor:pointer; border:2px solid transparent; }
.pdp-thumbs img.on, .pdp-thumbs img:hover { border-color:var(--orange); }
.pdp-info { display:flex; flex-direction:column; gap:16px; }
@media(max-width:740px){
  .pdp-wrap { grid-template-columns:1fr; gap:0; padding:0 0 60px; }
  .pdp-img-main { border-radius:0; height:320px; }
  .pdp-info { padding:20px; }
  .pdp-thumbs { padding:4px 20px 8px; }
}
</style>

<div style="background:var(--cream);min-height:80vh">
  <div class="pdp-wrap">

    <!-- GALERÍA FOTOS -->
    <div>
      {% if product.featured_image %}
        <img id="mainImg" class="pdp-img-main"
             src="{{ product.featured_image | img_url: '800x' }}"
             alt="{{ product.title | escape }}">
      {% else %}
        <div class="pdp-img-main" style="display:flex;align-items:center;justify-content:center;font-size:80px">&#x1F43E;</div>
      {% endif %}

      {% if product.images.size > 1 %}
        <div class="pdp-thumbs">
          {% for image in product.images limit: 12 %}
            <img src="{{ image | img_url: '160x160' }}"
                 data-full="{{ image | img_url: '800x' }}"
                 alt="{{ product.title | escape }}"
                 class="{% if forloop.first %}on{% endif %}"
                 onclick="swImg(this)">
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- INFO -->
    <div class="pdp-info">
      <div class="prod-brand">{{ product.type | default: 'PawLove' }}</div>

      <h1 style="font-family:'Fraunces',serif;font-size:clamp(22px,3vw,36px);font-weight:900;line-height:1.1;color:var(--brown)">
        {{ product.title }}
      </h1>

      <div style="color:var(--gold);font-size:16px">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</div>

      <div class="prod-prices">
        <span class="pp-now" style="font-size:28px">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="pp-old">{{ product.compare_at_price | money }}</span>
          {% assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="pp-save">-{{ saved }}%</span>
        {% endif %}
      </div>

      {% if product.description != blank %}
        <div style="font-size:14px;color:var(--gray);line-height:1.9;border-top:1px solid rgba(44,31,20,.07);padding-top:16px">
          {{ product.description }}
        </div>
      {% endif %}

      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" name="checkout" class="btn-primary" style="width:100%;justify-content:center;font-size:15px;padding:17px">
          &#x1F43E; Comprar ahora — {{ product.price | money }}
        </button>
      {% endform %}

      <div style="background:var(--warm);border-radius:14px;padding:14px 18px;font-size:13px;color:var(--gray);line-height:1.8">
        <strong style="color:var(--brown);display:block;margin-bottom:4px">&#x1F4E6; Envio</strong>
        Entrega 8-18 dias · Gratis en pedidos +40€
      </div>

      <a href="javascript:history.back()" style="font-size:13px;color:var(--gray);text-align:center;display:block">&#x2190; Volver</a>
    </div>

  </div>
</div>

<script>
function swImg(t){
  document.getElementById('mainImg').src=t.dataset.full;
  document.querySelectorAll('.pdp-thumbs img').forEach(i=>i.classList.remove('on'));
  t.classList.add('on');
}
</script>
