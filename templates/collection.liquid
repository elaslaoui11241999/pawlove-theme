<style>
@media(max-width:700px){
  .col-card { grid-template-columns:1fr !important; }
  .col-card > div:first-child img { max-height:280px; }
}
</style>
<nav class="navbar">
  <a href="{{ routes.root_url }}" class="nb-logo">
    <span class="paw">&#x1F43E;</span>Paw<span>Love</span>
  </a>
  <div class="nb-right">
    <a href="{{ routes.cart_url }}" class="nb-btn">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="nb-badge">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<div style="background:var(--cream);min-height:60vh">
  <div class="container section">

    <div class="sec-tag">&#x1F43E; {{ collection.title | default: 'Todos los productos' }}</div>
    <h1 class="sec-h">{{ collection.title | default: 'Todos los' }} <em>productos</em></h1>

    {% if collection.products_count == 0 %}
      <p style="color:var(--gray);text-align:center;padding:60px 0;font-size:15px">
        No hay productos en esta coleccion todavia.
      </p>
    {% else %}
      <div style="display:flex;flex-direction:column;gap:40px">
        {% for product in collection.products %}

          <div class="col-card" style="background:#fff;border-radius:24px;overflow:hidden;box-shadow:0 2px 20px rgba(44,31,20,.07);display:grid;grid-template-columns:1fr 1fr;align-items:stretch">

            <a href="{{ product.url }}" style="background:var(--warm);display:flex;flex-direction:column;gap:2px;text-decoration:none">
              {% assign images = product.images %}
              {% if images.size > 0 %}
                <div style="flex:2;overflow:hidden">
                  <img src="{{ images[0] | img_url: '800x800', crop: 'center' }}"
                       alt="{{ product.title | escape }}"
                       style="width:100%;height:100%;object-fit:cover;display:block">
                </div>
                {% if images.size > 1 %}
                  <div style="display:grid;grid-template-columns:repeat({{ images.size | minus: 1 | at_most: 3 }},1fr);gap:2px">
                    {% for image in images offset:1 limit:3 %}
                      <img src="{{ image | img_url: '400x300', crop: 'center' }}"
                           alt="{{ product.title | escape }}"
                           style="width:100%;height:120px;object-fit:cover;display:block">
                    {% endfor %}
                  </div>
                {% endif %}
              {% else %}
                <div style="flex:1;display:flex;align-items:center;justify-content:center;font-size:80px;padding:40px">&#x1F43E;</div>
              {% endif %}
            </a>

            <div style="padding:32px;display:flex;flex-direction:column;gap:16px;justify-content:center">
              {% if product.compare_at_price > product.price %}
                <span style="background:var(--orange);color:#fff;font-size:10px;font-weight:800;padding:4px 12px;border-radius:999px;width:fit-content;text-transform:uppercase">Oferta</span>
              {% endif %}

              <div class="prod-brand">{{ product.type | default: 'PawLove' }}</div>
              <a href="{{ product.url }}" style="text-decoration:none">
                <h2 style="font-family:'Fraunces',serif;font-size:clamp(20px,3vw,32px);font-weight:900;line-height:1.1;color:var(--brown)">
                  {{ product.title }}
                </h2>
              </a>

              <div class="prod-prices">
                <span class="pp-now" style="font-size:26px">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="pp-old">{{ product.compare_at_price | money }}</span>
                  {% assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="pp-save">-{{ saved }}%</span>
                {% endif %}
              </div>

              {% if product.description != blank %}
                <p style="font-size:14px;color:var(--gray);line-height:1.8">
                  {{ product.description | strip_html | truncate: 300 }}
                </p>
              {% endif %}

              <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px">
                <a href="{{ product.url }}" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:16px;border-radius:14px;font-size:15px;font-weight:800;background:var(--orange);color:#fff;text-decoration:none;text-align:center">
                  &#x1F43E; Ver producto y elegir
                </a>
                {% form 'product', product %}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" name="checkout" style="width:100%;padding:14px;border-radius:14px;font-size:14px;font-weight:700;border:1px solid rgba(44,31,20,.15);background:#fff;color:var(--brown);cursor:pointer">
                    Comprar ahora sin elegir &#x2014; {{ product.price | money }}
                  </button>
                {% endform %}
              </div>

              <div style="background:var(--warm);border-radius:12px;padding:12px 16px;font-size:12px;color:var(--gray)">
                &#x1F4E6; Entrega 8-18 dias &#x00B7; Gratis en pedidos +40&#x20AC;
              </div>
            </div>

          </div>

        {% endfor %}
      </div>
    {% endif %}

    <div style="text-align:center;margin-top:48px">
      <a href="{{ routes.root_url }}" class="btn-secondary">&#x2190; Volver al inicio</a>
    </div>

  </div>
</div>