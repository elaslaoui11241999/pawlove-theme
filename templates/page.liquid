<div style="background:var(--cream);min-height:60vh;padding:clamp(48px,7vw,96px) 20px">
  <div style="max-width:760px;margin:0 auto">
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--orange);margin-bottom:32px;">
      &#x2190; Volver al inicio
    </a>
    <h1 style="font-family:'Fraunces',serif;font-size:clamp(28px,5vw,48px);font-weight:900;color:var(--brown);margin-bottom:32px;line-height:1.1">{{ page.title }}</h1>
    <div style="font-size:15px;line-height:1.9;color:var(--gray)">
      {{ page.content }}
    </div>
  </div>
</div>
