    {
      "type": "text",
      "id": "product_count",
      "label": "Numero de productos",
      "default": "7"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Codigo descuento",
      "default": "PAWLOVE10"
    },
    {
      "type": "text",
      "id": "discount_pct",
      "label": "Porcentaje descuento",
      "default": "10"
    }
  ],
  "presets": [
    {
      "name": "Home"
    }
  ]
}
{% endschema %}
