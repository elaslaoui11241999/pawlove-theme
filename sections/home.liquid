    <div class="cat-grid">
      {% assign c_higiene = collections['higiene'] %}
      {% assign c_juguetes = collections['juguetes'] %}
      {% assign c_paseos = collections['paseos'] %}
      {% assign c_perros = collections['perros'] %}
      {% assign c_gatos = collections['gatos'] %}
      <a href="/collections/higiene" class="cat-card">
        <div class="cat-ico">&#x1FAA5;</div>
        <div class="cat-nm">Higiene</div>
        <div class="cat-ct">{% if c_higiene %}{{ c_higiene.products_count }}{% else %}0{% endif %} productos</div>
      </a>
      <a href="/collections/juguetes" class="cat-card">
        <div class="cat-ico">&#x1F3BE;</div>
        <div class="cat-nm">Juguetes</div>
        <div class="cat-ct">{% if c_juguetes %}{{ c_juguetes.products_count }}{% else %}0{% endif %} productos</div>
      </a>
      <a href="/collections/paseos" class="cat-card">
        <div class="cat-ico">&#x1F9AE;</div>
        <div class="cat-nm">Paseos</div>
        <div class="cat-ct">{% if c_paseos %}{{ c_paseos.products_count }}{% else %}0{% endif %} productos</div>
      </a>
      <a href="/collections/perros" class="cat-card">
        <div class="cat-ico">&#x1F436;</div>
        <div class="cat-nm">Perros</div>
        <div class="cat-ct">{% if c_perros %}{{ c_perros.products_count }}{% else %}0{% endif %} productos</div>
      </a>
      <a href="/collections/gatos" class="cat-card">
        <div class="cat-ico">&#x1F431;</div>
        <div class="cat-nm">Gatos</div>
        <div class="cat-ct">{% if c_gatos %}{{ c_gatos.products_count }}{% else %}0{% endif %} productos</div>
      </a>
      <a href="/collections/all" class="cat-card">
        <div class="cat-ico">&#x2728;</div>
        <div class="cat-nm">Ver todo</div>
        <div class="cat-ct">{{ collections.all.products_count }} productos</div>
      </a>
    </div>
  </div>
</div>

<!-- PRODUCTOS -->
<div id="productos" style="background:var(--warm)">
  <div class="container section">
    <div class="sec-tag">&#x2B50; Nuestros productos</div>
    <h2 class="sec-h" id="prod-title">Todos los <em>productos</em></h2>
    <div class="prod-grid" id="prodGrid">
      {% assign source = collections.all %}
      {% if section.settings.collection != blank %}
        {% assign source = collections[section.settings.collection] %}
      {% endif %}
      {% for product in source.products limit: 8 %}
        {% assign ptype = product.type | downcase %}
        <div class="prod-card" data-type="{{ product.type }}" data-handle="{{ product.handle }}">
          <div class="prod-img">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy"/>
            {% else %}
              <div style="font-size:60px;display:flex;align-items:center;justify-content:center;height:100%">&#x1F43E;</div>
            {% endif %}
            {% if product.compare_at_price > product.price %}
              <span class="prod-badge b-sale">Oferta</span>
            {% elsif product.tags contains 'nuevo' %}
              <span class="prod-badge b-new">Nuevo</span>
            {% elsif product.tags contains 'top' %}
              <span class="prod-badge b-hot">Top ventas</span>
            {% endif %}
            <button class="prod-ver"
              data-id="{{ product.first_available_variant.id }}"
              data-title="{{ product.title | escape }}"
              data-brand="{{ product.type | escape }}"
              data-price="{{ product.price | money }}"
              data-old="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | money }}{% endif %}"
              data-img="{% if product.featured_image %}{{ product.featured_image | img_url: '600x600', crop: 'center' }}{% endif %}"
              data-desc="{{ product.description | strip_html | truncate: 200 | escape }}"
              data-url="{{ product.url }}"
              onclick="openShopifyModal(this)">
              &#x1F43E; Comprar ahora
            </button>
          </div>
          <div class="prod-info">
            <div class="prod-brand">{{ product.type }}</div>
            <div class="prod-name">{{ product.title }}</div>
            <div class="prod-prices">
              <span class="pp-now">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="pp-old">{{ product.compare_at_price | money }}</span>
                {% assign saved = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <span class="pp-save">-{{ saved }}%</span>
              {% endif %}
            </div>
            <div class="prod-stars">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605; <span>({{ product.metafields.reviews.rating_count | default: '—' }})</span></div>
          </div>
        </div>
      {% else %}
        <p style="color:var(--gray);grid-column:1/-1;text-align:center;padding:40px">Proximamente nuevos productos.</p>
      {% endfor %}
    </div>
    <div style="text-align:center;margin-top:40px">
      <a href="/collections/all" class="btn-primary">Ver todos los productos &#x1F43E;</a>
    </div>
  </div>
</div>

